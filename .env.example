# Source de données : TheSportsDB — API gratuite, sans backend (CORS), qui couvre
# la Coupe du Monde 2026 en cours (league 4429, season 2026).
#
# "123" est la clé de test publique : elle fonctionne immédiatement, sans inscription.
# Pour lever les limites du tier de test, créez une clé gratuite :
# https://www.thesportsdb.com/free_sports_api
VITE_THESPORTSDB_KEY=123

# Optionnel : surcharges
# VITE_API_BASE_URL=https://www.thesportsdb.com/api/v1/json
# VITE_SEASON=2026
